# ============================================================
#  KICK START — Portal EB-3 · variáveis de ambiente
#  Copie para .env (o Prisma CLI lê .env; o Next também lê .env).
#  Em produção, configure estas variáveis no painel da Vercel.
# ============================================================

# --- Banco de dados (Neon Postgres) ---------------------------------
# Pegue a "Connection string" (pooled) no painel do Neon.
# Use a URL com ?sslmode=require.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Auth.js (NextAuth) ---------------------------------------------
# Segredo para assinar os tokens de sessão. Gere com: openssl rand -base64 32
AUTH_SECRET="troque-por-um-segredo-aleatorio"
# Em produção defina a URL pública (ex.: https://eb3.kick-start.us)
AUTH_URL="http://localhost:3000"

# --- Login com Google -----------------------------------------------
# Crie um "OAuth client ID" (tipo Web) no Google Cloud Console.
# Redirect URI autorizado: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- E-mail (Resend) ------------------------------------------------
# API key do Resend (resend.com → API Keys).
RESEND_API_KEY=""
# Remetente: precisa ser de um domínio verificado no Resend (SPF/DKIM).
# Ex.: "Kick Start EB-3 <portal@kick-start.us>"
MAIL_FROM="Kick Start EB-3 <portal@kick-start.us>"
# Destino das aplicações (caixa da equipe).
MAIL_TO="info@kick-start.us"

# --- Vagas do site (WP Job Manager) ---------------------------------
# Seção "Outras vagas" da home puxa o board do kick-start.us ao vivo.
# Os defaults já apontam pro site; só defina se mudar de domínio/endpoint.
# WP_JOBS_API="https://kick-start.us/wp-json/wp/v2/job-listings"
# WP_JOBS_BOARD_URL="https://kick-start.us/our-vacancies-all-jobs/"
