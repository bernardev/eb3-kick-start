# ============================================================
#  KICK START — Portal EB-3 · variáveis de ambiente
#  Copie para .env (o Prisma CLI lê .env; o Next também lê .env).
#  Em produção, configure estas variáveis no painel da Vercel.
# ============================================================

# --- Banco de dados (Neon Postgres) ---------------------------------
# Pegue a "Connection string" (pooled) no painel do Neon.
# Use a URL com ?sslmode=require.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Auth.js (NextAuth) ---------------------------------------------
# Segredo para assinar os tokens de sessão. Gere com: openssl rand -base64 32
AUTH_SECRET="troque-por-um-segredo-aleatorio"
# Em produção defina a URL pública (ex.: https://eb3.kick-start.us)
AUTH_URL="http://localhost:3000"

# --- Login com Google -----------------------------------------------
# Crie um "OAuth client ID" (tipo Web) no Google Cloud Console.
# Redirect URI autorizado: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- E-mail ---------------------------------------------------------
# Remetente e destino das aplicações (sempre necessários).
MAIL_FROM="Kick Start EB-3 <info@kick-start.us>"
MAIL_TO="info@kick-start.us"

# Opção A (recomendada): SMTP — Gmail/Google Workspace, HostGator, etc.
# Para Gmail/Workspace: ative a verificação em 2 etapas e gere uma "App Password".
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"            # 465 = SSL · 587 = STARTTLS
SMTP_USER="info@kick-start.us"
SMTP_PASS=""              # App Password do Google (16 caracteres) — NUNCA commitar

# Opção B (alternativa): Resend (se preferir um provedor transacional).
# Usado só se SMTP_HOST estiver vazio. Requer domínio verificado no Resend.
# RESEND_API_KEY=""

# --- Atendimento (WhatsApp) -----------------------------------------
# Número (só dígitos, com DDI). Padrão: +1 858-744-7190.
# SUPPORT_WHATSAPP_NUMBER="18587447190"

# --- Vagas do site (WP Job Manager) ---------------------------------
# Seção "Outras vagas" da home puxa o board do kick-start.us ao vivo.
# Os defaults já apontam pro site; só defina se mudar de domínio/endpoint.
# WP_JOBS_API="https://kick-start.us/wp-json/wp/v2/job-listings"
# WP_JOBS_BOARD_URL="https://kick-start.us/our-vacancies-all-jobs/"
# Categorias de visto a NÃO mostrar em "Outras vagas" (EB-3 já fica no topo).
# WP_JOBS_EXCLUDE="EB-3"
